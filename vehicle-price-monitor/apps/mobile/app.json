{
  "expo": {
    "name": "PricePulse",
    "slug": "vehicle-price-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vehicle-price-monitor",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vehiclepricemonitor.app"
    },
    "android": {
      "package": "com.vehiclepricemonitor.app",
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
